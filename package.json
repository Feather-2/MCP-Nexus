{
  "name": "MCP-Nexus",
  "version": "1.0.0",
  "description": " MCP Nexus - TypeScript MCP Protocol Gateway Platform",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "gui": "tsx start-gui.js",
    "web": "tsx start-gui.js",
    "dashboard": "tsx start-gui.js",
    "quick-start": "tsx quick-start.js",
    "demo": "tsx quick-start.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "build:docker": "docker build -t MCP-Nexus:local .",
    "pack:portable": "node scripts/make-portable.cjs",
    "pack:portable:clean": "rimraf release || rd /s /q release"
  },
  "keywords": [
    "mcp",
    "protocol",
    "gateway",
    "typescript",
    "paper-burner"
  ],
  "author": "MCP Nexus Team",
  "license": "Apache-2.0",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^8.0.0",
    "@fastify/static": "^7.0.4",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "fastify": "^4.25.2",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.33",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^1.2.0",
    "better-sqlite3": "^12.6.2",
    "eslint": "^8.56.0",
    "rimraf": "^6.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
