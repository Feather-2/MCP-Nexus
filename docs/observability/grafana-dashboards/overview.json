{
  "dashboard": {
    "title": "MCP-Nexus Observability Overview",
    "tags": ["mcp-nexus", "observability"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "执行成功率",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
        "targets": [{
          "expr": "sum(rate(orchestrator_execute_success_total[5m])) / sum(rate(orchestrator_execute_total[5m]))",
          "legendFormat": "成功率"
        }],
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
          "textMode": "value_and_name"
        }
      },
      {
        "id": 2,
        "title": "平均执行时长",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 8, "y": 0},
        "targets": [{
          "expr": "histogram_quantile(0.50, rate(orchestrator_execute_duration_ms_bucket[5m]))",
          "legendFormat": "P50"
        }],
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
          "textMode": "value_and_name"
        }
      },
      {
        "id": 3,
        "title": "并发执行数",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
        "targets": [{
          "expr": "sum(orchestrator_concurrent_executions)",
          "legendFormat": "并发数"
        }],
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
          "textMode": "value_and_name"
        }
      },
      {
        "id": 4,
        "title": "执行时长分布 (P50/P95/P99)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4},
        "targets": [
          {"expr": "histogram_quantile(0.50, rate(orchestrator_execute_duration_ms_bucket[5m]))", "legendFormat": "P50"},
          {"expr": "histogram_quantile(0.95, rate(orchestrator_execute_duration_ms_bucket[5m]))", "legendFormat": "P95"},
          {"expr": "histogram_quantile(0.99, rate(orchestrator_execute_duration_ms_bucket[5m]))", "legendFormat": "P99"}
        ]
      },
      {
        "id": 5,
        "title": "步骤失败率趋势",
        "type": "graph",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
        "targets": [{
          "expr": "rate(orchestrator_step_error_total[5m])",
          "legendFormat": "失败率"
        }]
      }
    ]
  }
}
